# ═════════════════════════════════════════════════════════════════════════════
# .GITIGNORE
# Files and directories to exclude from version control
# ═════════════════════════════════════════════════════════════════════════════

# Python Virtual Environment
venv/
env/
ENV/
.venv

# Python Cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# IDE and Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.project
.pydevproject
.settings/

# Environment Variables (Never commit real keys!)
.env
.env.local
.env.*.local

# Logs
logs/
*.log
*.log.*

# Model Files (Large - regenerate on demand)
saved_bug_predictor_model/
training_outputs/
*.bin
*.pt
*.pth

# Jupiter Notebooks
.ipynb_checkpoints/
*.ipynb

# OS-specific
Thumbs.db
.DS_Store

# Testing
.pytest_cache/
.coverage
htmlcov/

# Temporary Files
*.tmp
*.temp
temp/
tmp/

# User-specific files
*.swp
*.swo
*~
.~*

# Lock files (optional - include if using specific versions)
# poetry.lock
# Pipfile.lock
